DISCORD_TOKEN=
CLIENT_ID=
# Optional for faster command updates during development (commands only).
# Leave empty to register global commands for all servers.
COMMAND_GUILD_ID=
# Optional legacy guild id used by some integrations as a fallback.
GUILD_ID=
# Optional currency emoji for shop buttons (examples: 🍬 or <:candy:123456789012345678>)
CURRENCY_EMOJI=🍬

# Payments backend (PayPal)
PAYMENTS_PORT=8787
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=USD
PAYPAL_SLOT_PRICE=2.99
# Scope used when granting paid slots (defaults to GUILD_ID when empty)
PAYPAL_SLOT_SCOPE=
